{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm install:*)",
      "Bash(npm run:*)",
      "Bash(npx prisma:*)",
      "Bash(npx nest:*)",
      "Bash(npx jest:*)",
      "Bash(npx prettier:*)",
      "Bash(docker compose:*)",
      "Bash(docker ps:*)",
      "Bash(docker logs:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(pwd)",
      "Read(//Users/macbook/projects/power-bank-rental/**)",
      "Edit(//Users/macbook/projects/power-bank-rental/**)",
      "Write(//Users/macbook/projects/power-bank-rental/**)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(prisma migrate reset:*)",
      "Read(//Users/macbook/projects/power-bank-rental/.env*)",
      "Read(//Users/macbook/projects/power-bank-rental/**/secrets/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/block-no-verify.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/format-on-edit.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/typecheck-on-stop.sh"
          }
        ]
      }
    ]
  },
  "env": {
    "NODE_OPTIONS": "--max-old-space-size=4096"
  }
}
