{
  "name": "backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "build": "./scripts/run-node.sh ./node_modules/@nestjs/cli/bin/nest.js build",
    "db:seed": "./scripts/run-node.sh prisma/seed.js",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "predb:seed": "npm run build",
    "start": "./scripts/run-node.sh ./node_modules/@nestjs/cli/bin/nest.js start --exec ./scripts/run-node.sh",
    "start:dev": "./scripts/run-node.sh ./node_modules/@nestjs/cli/bin/nest.js start --watch --exec ./scripts/run-node.sh",
    "start:debug": "./scripts/run-node.sh ./node_modules/@nestjs/cli/bin/nest.js start --debug --watch --exec ./scripts/run-node.sh",
    "start:prod": "./scripts/run-node.sh dist/src/main.js",
    "mqtt:broker": "./scripts/run-node.sh ./test/mocks/mqtt-broker.mjs",
    "mqtt:simulator": "./scripts/run-node.sh ./test/mocks/cabinet-simulator.mjs",
    "mqtt:smoke": "./scripts/run-node.sh ./test/mocks/mqtt-smoke.mjs",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "prepare": "cd .. && husky backend/.husky",
    "test": "./scripts/run-node.sh --experimental-vm-modules ./node_modules/jest/bin/jest.js",
    "test:watch": "./scripts/run-node.sh --experimental-vm-modules ./node_modules/jest/bin/jest.js --watch",
    "test:cov": "./scripts/run-node.sh --experimental-vm-modules ./node_modules/jest/bin/jest.js --coverage",
    "test:debug": "./scripts/run-node.sh --experimental-vm-modules --inspect-brk ./node_modules/jest/bin/jest.js --runInBand",
    "test:e2e": "./scripts/run-node.sh --experimental-vm-modules ./node_modules/jest/bin/jest.js --config ./test/jest-e2e.config.cjs"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.3.2",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "mqtt": "^5.15.1",
    "nestjs-pino": "^4.6.1",
    "openid-client": "^5.7.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.7.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/passport": "^1.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.2",
    "aedes": "^1.0.2",
    "dotenv": "^17.4.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "jest": "^30.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "prisma": {
    "seed": "npm run db:seed"
  }
}
